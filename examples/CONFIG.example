#!/usr/bin/bash

# Example CONFIG for post_rnadnavar_mupexi_prep.
# Workflow names:
# - RNA steps:  rna1 .. rna7
# - gDNA steps: gdna1 .. gdna4

# SAMPLES file: first column is sample ID with suffix label, e.g.
#   Pat1_DNA_NORMAL
#   Pat1_DNA_TUMOR
#   Pat1_RNA_TUMOR
samples="/path/to/SAMPLES.tsv"

# Working directories
vcfdir="/path/to/project/variant_calling/mutect2"
bamdir="/path/to/project/preprocessing/markduplicates"
dna_bam_suffix="md.bam"

# Helper scripts directory (inside this repo).
rnae_scripts="/path/to/this/repo/post_rnadnavar_mupexi_prep/rnae_script"

# Optional PBS defaults
qsub_group="srhgroup"
qsub_account="srhgroup"

# References
knownsites="/path/to/KnownSites_merged.with_source.collapsed.clean.tsv.gz"
FASTA="/path/to/reference.fa.gz"
DICT="/path/to/reference.dict"

# Label variables used for matching sample suffixes in SAMPLES/VCF/BAM headers.
dna_normal_label="DNA_NORMAL"
dna_tumor_label="DNA_TUMOR"
rna_tumor_label="RNA_TUMOR"

# Standardized output names for merged outputs.
out_dna_normal_label="DNA_NORMAL"
out_dna_tumor_label="${dna_tumor_label}"
out_rna_tumor_label="${rna_tumor_label}"

# gDNA output suffixes
# Expected under: ${vcfdir}/${patient}_${out_dna_normal_label}/
gdna1_vcf_extension="gdna1.HaplotypeCaller.vcf"
gdna2_vcf_extension="gdna2.Filtered.HaplotypeCaller.vcf"
gdna3_vcf_extension="gdna3.Filtered.Selected.HaplotypeCaller.vcf"
gdna4_vcf_extension="gdna4.Filtered.vcf"

# Which gDNA VCF suffix rna6 should merge (defaults to gdna4_vcf_extension).
ndna_vcf="${gdna4_vcf_extension}"

# gDNA filtering knobs
germline_min_dp=10
germline_min_qd=2.0
germline_proximity_distance=33

# gdna4 RNA-proximity source control:
# - auto (recommended): include RNA proximity when RNA VCF is found
# - 1: require attempt, warn+fallback to DNA-only if RNA VCF missing
# - 0: DNA-only
germline_include_rna_proximity="auto"
# Optional explicit override (supports {patient} placeholder):
# germline_rna_proximity_vcf="/path/to/{patient}_rna5.knownsites_summarised_qced.vcf.gz"
# Optional extension override in patient RNA-vs-normal folder:
# germline_rna_proximity_vcf_extension="rna5.knownsites_summarised_qced.vcf.gz"

# RNA output suffixes
# Expected under: ${vcfdir}/${patient}_${out_rna_tumor_label}_vs_${patient}_${out_dna_normal_label}/
# Upstream mutect2 VCF suffixes produced by rnadnavar (inputs to rna1):
# Full source path pattern used by rna1:
#   RNA source: ${vcfdir}/${patient}_${out_rna_tumor_label}_vs_${patient}_${out_dna_normal_label}/${patient}_${source_rna_mutect2_vcf_extension}
#   DNA source: ${vcfdir}/${patient}_${out_dna_tumor_label}_vs_${patient}_${out_dna_normal_label}/${patient}_${source_dna_mutect2_vcf_extension}
# You can use "{patient}" placeholder in these suffixes.
source_rna_mutect2_vcf_extension="${out_rna_tumor_label}_vs_{patient}_${out_dna_normal_label}.mutect2.filtered.vcf.gz"
source_dna_mutect2_vcf_extension="${out_dna_tumor_label}_vs_{patient}_${out_dna_normal_label}.mutect2.filtered.vcf.gz"

# RNA pipeline outputs
rna1_vcf_extension="rna1.filtered_minus_dna_positions.vcf.gz"
rna2_split_vcf_extension="rna2.filtered_minus_dna_positions.split.vcf.gz"
rna2_labeled_vcf_extension="rna2.filtered_edit_labeled.vcf.gz"
rna3_knownsites_vcf_extension="rna3.filtered_edit_labeled.knownsites.vcf.gz"
rna4_summarised_vcf_extension="rna4.filtered_edit_labeled.knownsites_summarised.vcf.gz"
rna5_qced_vcf_extension="rna5.filtered_edit_labeled.knownsites_summarised_qced.vcf.gz"
rna6_merged_vcf_extension="rna6.DNAt_DNAn_RNAt_merged.vcf.gz"
rna7_genotyped_vcf_extension="rna7.DNAt_DNAn_RNAt_merged_genotyped.vcf.gz"
rna7_phased_vcf_extension="rna7.DNAt_DNAn_RNAt_merged_phased.vcf.gz"

# Required rna7.0 output suffix (rna7 consumes this BAM)
rna7_smfixed_bam_suffix="RNA_TUMOUR.md.SMfixed.bam"

# Optional module profile override (wrappers default to REPO/pipeline_defaults/toolchain.defaults.sh).
# You can define these in CONFIG to override repo defaults:
# module_gatk="gatk/4.5.0.0"
# modules_rna="ngs tools htslib/1.23 bcftools/1.23 ${module_gatk} anaconda3/2025.06-1"
# modules_gdna_hc="tools ngs java/17-openjdk ${module_gatk}"

# DNA-only path (no RNA): merge germline + DNA somatic, then genotype/phase DNA tumor
# If unset, defaults are used by dna_only_merge_and_phase.sh.
# germline_for_merge_extension defaults to gdna4_vcf_extension (or output_extension_30 in legacy config).
dna_only_merged_vcf_extension="dna_only6.DNAt_DNAn_merged.vcf.gz"
dna_only_genotyped_vcf_extension="dna_only7.DNAt_DNAn_merged_genotyped.vcf.gz"
dna_only_phased_vcf_extension="dna_only7.DNAt_DNAn_merged_phased.vcf.gz"
